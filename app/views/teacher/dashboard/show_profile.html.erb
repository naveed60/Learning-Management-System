<% teacher_initials = current_teacher.name.to_s.split.map { |part| part[0] }.join.first(2).to_s.upcase.presence || "T" %>
<% teacher_courses = current_teacher.courses %>

<section class="teacher-profile-v2">
  <div class="teacher-profile-v2__shell">
    <div class="teacher-profile-v2__hero">
      <div class="teacher-profile-v2__hero-grid">
        <div class="teacher-profile-v2__identity">
          <div class="teacher-profile-v2__avatar"><%= teacher_initials %></div>

          <div>
            <div class="teacher-profile-v2__eyebrow">
              <i class="bi bi-stars"></i>
              Teacher Profile
            </div>
            <h1 class="teacher-profile-v2__name"><%= current_teacher.name %></h1>
            <p class="teacher-profile-v2__email"><%= current_teacher.email %></p>

            <div class="teacher-profile-v2__chips">
              <div class="teacher-profile-v2__chip">
                <i class="bi bi-person-badge"></i>
                ID <%= current_teacher.id %>
              </div>
              <div class="teacher-profile-v2__chip">
                <i class="bi bi-envelope"></i>
                Faculty Account
              </div>
              <div class="teacher-profile-v2__chip">
                <i class="bi bi-journal-bookmark"></i>
                <%= pluralize(teacher_courses.count, "Course") %>
              </div>
            </div>
          </div>
        </div>

        <div class="teacher-profile-v2__stats">
          <div class="teacher-profile-v2__stat">
            <span>Phone</span>
            <strong><%= current_teacher.phone_number.presence || "-" %></strong>
          </div>
          <div class="teacher-profile-v2__stat">
            <span>Status</span>
            <strong>Active Teacher</strong>
          </div>
          <div class="teacher-profile-v2__stat">
            <span>Courses</span>
            <strong><%= teacher_courses.count %></strong>
          </div>
        </div>
      </div>
    </div>

    <div class="teacher-profile-v2__body">
      <article class="teacher-profile-v2__panel">
        <div class="teacher-profile-v2__panel-head">
          <div>
            <p class="teacher-profile-v2__panel-kicker">Personal Details</p>
            <h2 class="teacher-profile-v2__panel-title">Personal Information</h2>
          </div>
          <div class="teacher-profile-v2__panel-icon">
            <i class="bi bi-person-circle"></i>
          </div>
        </div>

        <div class="teacher-profile-v2__fields">
          <div class="teacher-profile-v2__field">
            <span class="teacher-profile-v2__field-label">Father's Name</span>
            <span class="teacher-profile-v2__field-value"><%= current_teacher.father_name.presence || "-" %></span>
          </div>
          <div class="teacher-profile-v2__field">
            <span class="teacher-profile-v2__field-label">Email Address</span>
            <span class="teacher-profile-v2__field-value"><%= current_teacher.email %></span>
          </div>
          <div class="teacher-profile-v2__field">
            <span class="teacher-profile-v2__field-label">Phone Number</span>
            <span class="teacher-profile-v2__field-value"><%= current_teacher.phone_number.presence || "-" %></span>
          </div>
          <div class="teacher-profile-v2__field">
            <span class="teacher-profile-v2__field-label">Date of Birth</span>
            <span class="teacher-profile-v2__field-value"><%= current_teacher.dob&.strftime("%B %d, %Y") || "-" %></span>
          </div>
          <div class="teacher-profile-v2__field">
            <span class="teacher-profile-v2__field-label">Address</span>
            <span class="teacher-profile-v2__field-value"><%= current_teacher.address.presence || "-" %></span>
          </div>
        </div>
      </article>

      <article class="teacher-profile-v2__panel">
        <div class="teacher-profile-v2__panel-head">
          <div>
            <p class="teacher-profile-v2__panel-kicker">Academic Details</p>
            <h2 class="teacher-profile-v2__panel-title">Academic Information</h2>
          </div>
          <div class="teacher-profile-v2__panel-icon">
            <i class="bi bi-journal-bookmark"></i>
          </div>
        </div>

        <div class="teacher-profile-v2__fields">
          <div class="teacher-profile-v2__field">
            <span class="teacher-profile-v2__field-label">Teacher ID</span>
            <span class="teacher-profile-v2__field-value"><%= current_teacher.id %></span>
          </div>
          <div class="teacher-profile-v2__field">
            <span class="teacher-profile-v2__field-label">Assigned Courses</span>
            <span class="teacher-profile-v2__field-value">
              <% if teacher_courses.any? %>
                <span class="teacher-profile-v2__courses">
                  <% teacher_courses.each do |course| %>
                    <span class="teacher-profile-v2__course"><%= course.name %></span>
                  <% end %>
                </span>
              <% else %>
                <span class="teacher-profile-v2__empty">No courses assigned</span>
              <% end %>
            </span>
          </div>
          <div class="teacher-profile-v2__field">
            <span class="teacher-profile-v2__field-label">Profile Status</span>
            <span class="teacher-profile-v2__field-value">Active Teacher</span>
          </div>
          <div class="teacher-profile-v2__field">
            <span class="teacher-profile-v2__field-label">Last Updated</span>
            <span class="teacher-profile-v2__field-value"><%= Time.current.strftime("%b %d, %Y") %></span>
          </div>
        </div>
      </article>
    </div>

    <div class="teacher-profile-v2__footer">
      <p class="teacher-profile-v2__updated">Profile overview updated on <%= Time.current.strftime("%B %d, %Y") %></p>
      <%= link_to teacher_root_path, class: "teacher-profile-v2__button" do %>
        <i class="bi bi-arrow-left"></i>
        Back to Dashboard
      <% end %>
    </div>
  </div>
</section>
