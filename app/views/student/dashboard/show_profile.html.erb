<% current_semester = current_student.semesters.last %>
<% student_initials = current_student.name.to_s.split.map { |part| part[0] }.join.first(2).to_s.upcase.presence || "S" %>

<section class="student-profile-v2">
  <div class="student-profile-v2__shell">
    <div class="student-profile-v2__hero">
      <div class="student-profile-v2__hero-grid">
        <div class="student-profile-v2__identity">
          <% if @student.image.attached? %>
            <%= image_tag @student.image, class: "student-profile-v2__avatar-image", alt: "#{current_student.name} profile photo" %>
          <% else %>
            <div class="student-profile-v2__avatar"><%= student_initials %></div>
          <% end %>

          <div>
            <div class="student-profile-v2__eyebrow">
              <i class="bi bi-stars"></i>
              Student Profile
            </div>
            <h1 class="student-profile-v2__name"><%= current_student.name %></h1>
            <p class="student-profile-v2__email"><%= current_student.email %></p>

            <div class="student-profile-v2__chips">
              <div class="student-profile-v2__chip">
                <i class="bi bi-person-badge"></i>
                ID <%= current_student.id %>
              </div>
              <div class="student-profile-v2__chip">
                <i class="bi bi-mortarboard"></i>
                Semester <%= current_semester&.semester_number || "-" %>
              </div>
              <div class="student-profile-v2__chip">
                <i class="bi bi-layers"></i>
                <%= current_semester&.semester_type || "Not assigned" %>
              </div>
            </div>
          </div>
        </div>

        <div class="student-profile-v2__stats">
          <div class="student-profile-v2__stat">
            <span>Batch</span>
            <strong><%= current_student.batch_id || "-" %></strong>
          </div>
          <div class="student-profile-v2__stat">
            <span>Phone</span>
            <strong><%= current_student.phone_number.presence || "-" %></strong>
          </div>
          <div class="student-profile-v2__stat">
            <span>Status</span>
            <strong>Active Student</strong>
          </div>
        </div>
      </div>
    </div>

    <div class="student-profile-v2__body">
      <article class="student-profile-v2__panel">
        <div class="student-profile-v2__panel-head">
          <div>
            <p class="student-profile-v2__panel-kicker">Personal Details</p>
            <h2 class="student-profile-v2__panel-title">Personal Information</h2>
          </div>
          <div class="student-profile-v2__panel-icon">
            <i class="bi bi-person-circle"></i>
          </div>
        </div>

        <div class="student-profile-v2__fields">
          <div class="student-profile-v2__field">
            <span class="student-profile-v2__field-label">Father's Name</span>
            <span class="student-profile-v2__field-value"><%= current_student.father_name.presence || "-" %></span>
          </div>
          <div class="student-profile-v2__field">
            <span class="student-profile-v2__field-label">Phone Number</span>
            <span class="student-profile-v2__field-value"><%= current_student.phone_number.presence || "-" %></span>
          </div>
          <div class="student-profile-v2__field">
            <span class="student-profile-v2__field-label">Date of Birth</span>
            <span class="student-profile-v2__field-value"><%= current_student.dob&.strftime("%B %d, %Y") || "-" %></span>
          </div>
          <div class="student-profile-v2__field">
            <span class="student-profile-v2__field-label">Email Address</span>
            <span class="student-profile-v2__field-value"><%= current_student.email %></span>
          </div>
        </div>
      </article>

      <article class="student-profile-v2__panel">
        <div class="student-profile-v2__panel-head">
          <div>
            <p class="student-profile-v2__panel-kicker">Academic Details</p>
            <h2 class="student-profile-v2__panel-title">Academic Information</h2>
          </div>
          <div class="student-profile-v2__panel-icon">
            <i class="bi bi-journal-bookmark"></i>
          </div>
        </div>

        <div class="student-profile-v2__fields">
          <div class="student-profile-v2__field">
            <span class="student-profile-v2__field-label">Batch Number</span>
            <span class="student-profile-v2__field-value"><%= current_student.batch_id || "-" %></span>
          </div>
          <div class="student-profile-v2__field">
            <span class="student-profile-v2__field-label">Current Semester Type</span>
            <span class="student-profile-v2__field-value"><%= current_semester&.semester_type || "-" %></span>
          </div>
          <div class="student-profile-v2__field">
            <span class="student-profile-v2__field-label">Current Semester</span>
            <span class="student-profile-v2__field-value"><%= current_semester&.semester_number || "-" %></span>
          </div>
          <div class="student-profile-v2__field">
            <span class="student-profile-v2__field-label">Last Updated</span>
            <span class="student-profile-v2__field-value"><%= Time.current.strftime("%b %d, %Y") %></span>
          </div>
        </div>
      </article>
    </div>

    <div class="student-profile-v2__footer">
      <p class="student-profile-v2__updated">Profile overview updated on <%= Time.current.strftime("%B %d, %Y") %></p>
      <%= link_to student_root_path, class: "student-profile-v2__button" do %>
        <i class="bi bi-arrow-left"></i>
        Back to Dashboard
      <% end %>
    </div>
  </div>
</section>
