<section class="course-admin course-admin--form">
  <div class="course-admin__shell course-admin__shell--form">
    <header class="course-admin__header course-admin__header--form">
      <div>
        <p class="course-admin__eyebrow">
          <%= student.persisted? ? "Update Student" : "Create Student" %>
        </p>
        <h1 class="course-admin__title">
          <%= student.persisted? ? "Edit Student" : "Add Student" %>
        </h1>
        <p class="course-admin__subtitle">
          Capture profile, batch, and semester details in one place for accurate enrollment tracking.
        </p>
      </div>
      <%= link_to "Back to Students", admin_students_path, class: "course-admin__ghost-link" %>
    </header>

    <div class="course-admin__form-shell">
      <%= form_for [:admin, student], html: { class: "course-admin__form", data: { turbo: true } } do |f| %>
        <%= render "shared/error", model: student %>

        <div class="course-admin__field">
          <%= f.label :name, "Name", class: "course-admin__label" %>
          <%= f.text_field :name, placeholder: "Enter full name", class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :father_name, "Father Name", class: "course-admin__label" %>
          <%= f.text_field :father_name, placeholder: "Enter father name", class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :email, "Email", class: "course-admin__label" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "name@example.com", class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :phone_number, "Phone Number", class: "course-admin__label" %>
          <%= f.telephone_field :phone_number, placeholder: "03XXXXXXXXX", class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :password, "Password", class: "course-admin__label" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "course-admin__input" %>
          <% if @minimum_password_length %>
            <span class="course-admin__meta"><%= @minimum_password_length %> characters minimum</span>
          <% end %>
        </div>

        <div class="course-admin__field">
          <%= f.label :password_confirmation, "Confirm Password", class: "course-admin__label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :dob, "Date of Birth", class: "course-admin__label" %>
          <%= f.date_field :dob, class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :image, "Image", class: "course-admin__label" %>
          <%= f.file_field :image, class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :batch_id, "Batch Number", class: "course-admin__label" %>
          <%= f.select :batch_id,
              Batch.all.collect { |item| [item.batch_number, item.id] },
              { include_blank: "Select batch" },
              class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= label_tag :semester_id, "Semester", class: "course-admin__label" %>
          <%= select_tag "semester_id",
              options_for_select(Semester.all.map { |item| ["#{item.semester_number} - #{item.semester_type}", item.id] }),
              class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= label_tag :semester_year, "Semester Year", class: "course-admin__label" %>
          <%= text_field_tag "semester_year", nil, class: "course-admin__input", placeholder: "e.g. 2026" %>
        </div>

        <div class="course-admin__form-actions">
          <%= link_to "Cancel", admin_students_path, class: "course-admin__secondary-button" %>
          <%= f.submit(student.persisted? ? "Save Changes" : "Create Student", class: "course-admin__primary-button") %>
        </div>
      <% end %>
    </div>
  </div>
</section>
