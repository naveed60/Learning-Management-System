<section class="course-admin course-admin--form">
  <div class="course-admin__shell course-admin__shell--form">
    <header class="course-admin__header course-admin__header--form">
      <div>
        <p class="course-admin__eyebrow">
          <%= enrollment.persisted? ? "Update Enrollment" : "Create Enrollment" %>
        </p>
        <h1 class="course-admin__title">
          <%= enrollment.persisted? ? "Edit Enrollment" : "Add Enrollment" %>
        </h1>
        <p class="course-admin__subtitle">
          Assign students to the correct section and grade so results and semester records stay in sync.
        </p>
      </div>
      <%= link_to "Back to Enrollments", admin_enrollments_path, class: "course-admin__ghost-link" %>
    </header>

    <div class="course-admin__form-shell">
      <%= form_for [:admin, enrollment], html: { class: "course-admin__form" } do |f| %>
        <%= render "shared/error", model: enrollment %>

        <div class="course-admin__field">
          <%= f.label :student_id, "Student", class: "course-admin__label" %>
          <%= f.select :student_id,
              options_from_collection_for_select(Student.all, :id, :name, f.object.student_id),
              { prompt: "Select a student" },
              class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= label_tag :teacher_id, "Teacher(s)", class: "course-admin__label" %>
          <%= select_tag :teacher_id,
              options_from_collection_for_select(Teacher.all, :id, :name, enrollment&.section&.teacher_id),
              multiple: true,
              class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :section_id, "Course & Section", class: "course-admin__label" %>
          <%= f.select :section_id,
              options_for_select(Section.all.map { |item| ["#{item.course.name} - #{item.name}", item.id] }, f.object.section_id),
              { prompt: "Select course & section" },
              class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :grade_id, "Grade", class: "course-admin__label" %>
          <%= f.collection_select :grade_id,
              Grade.all, :id, :letter,
              { selected: enrollment.grade_id, prompt: "Select grade" },
              class: "course-admin__input" %>
        </div>

        <div class="course-admin__form-actions">
          <%= link_to "Cancel", admin_enrollments_path, class: "course-admin__secondary-button" %>
          <%= f.submit(enrollment.persisted? ? "Save Changes" : "Create Enrollment", class: "course-admin__primary-button") %>
        </div>
      <% end %>
    </div>
  </div>
</section>
