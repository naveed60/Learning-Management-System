<section class="course-admin course-admin--form">
  <div class="course-admin__shell course-admin__shell--form">
    <header class="course-admin__header course-admin__header--form">
      <div>
        <p class="course-admin__eyebrow">
          <%= section.persisted? ? "Update Section" : "Create Section" %>
        </p>
        <h1 class="course-admin__title">
          <%= section.persisted? ? "Edit Section" : "Add Section" %>
        </h1>
        <p class="course-admin__subtitle">
          Link each section with the right course, teacher, and semester for cleaner scheduling.
        </p>
      </div>
      <%= link_to "Back to Sections", admin_sections_path, class: "course-admin__ghost-link" %>
    </header>

    <div class="course-admin__form-shell">
      <%= form_for [:admin, section], html: { class: "course-admin__form" } do |f| %>
        <%= render "shared/error", model: section %>

        <div class="course-admin__field">
          <%= f.label :course_id, "Course", class: "course-admin__label" %>
          <%= f.select :course_id,
              options_from_collection_for_select(Course.all, :id, :name, f.object.course_id),
              { prompt: "Select a course" },
              class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :teacher_id, "Teacher", class: "course-admin__label" %>
          <%= f.select :teacher_id,
              options_from_collection_for_select(Teacher.all, :id, :name, f.object.teacher_id),
              { prompt: "Select a teacher" },
              class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :semester_id, "Semester", class: "course-admin__label" %>
          <%= f.select :semester_id,
              options_for_select(Semester.all.map { |item| ["#{item.semester_number} - #{item.semester_type}", item.id] }, f.object.semester_id),
              { prompt: "Select semester" },
              class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :name, "Section Name", class: "course-admin__label" %>
          <%= f.text_field :name, placeholder: "Enter section name", autofocus: true, class: "course-admin__input" %>
        </div>

        <div class="course-admin__form-actions">
          <%= link_to "Cancel", admin_sections_path, class: "course-admin__secondary-button" %>
          <%= f.submit(section.persisted? ? "Save Changes" : "Create Section", class: "course-admin__primary-button") %>
        </div>
      <% end %>
    </div>
  </div>
</section>
