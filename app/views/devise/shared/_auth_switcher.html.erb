<% registerable = devise_mapping.registerable? %>
<% mode = local_assigns.fetch(:active_mode, :login).to_s %>
<% initial_mode = registerable && mode == "register" ? "register" : "login" %>
<% login_resource = local_assigns[:login_resource] || resource_class.new %>
<% register_resource = local_assigns[:register_resource] || resource_class.new %>

<section class="auth-register">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-10 col-xl-9">
        <div class="auth-switcher <%= "is-register" if initial_mode == "register" %>" data-controller="auth-switcher" data-auth-switcher-registerable-value="<%= registerable %>">
          <aside class="auth-switcher__welcome">
            <h2 class="auth-switcher__welcome-title">Welcome</h2>
            <p class="auth-switcher__welcome-copy auth-switcher__welcome-copy--login">
              Join our unique platform and explore a new experience.
            </p>
            <p class="auth-switcher__welcome-copy auth-switcher__welcome-copy--register">
              Already registered? Sign in to continue your learning journey.
            </p>

            <% if registerable %>
              <button type="button" class="btn auth-switcher__welcome-button auth-switcher__welcome-button--register" data-action="click->auth-switcher#toggle" data-auth-toggle-target="register">
                Register
              </button>
              <button type="button" class="btn auth-switcher__welcome-button auth-switcher__welcome-button--login" data-action="click->auth-switcher#toggle" data-auth-toggle-target="login">
                Login
              </button>
            <% end %>
          </aside>

          <div class="auth-switcher__panel">
            <% if registerable %>
              <div class="auth-switcher__tabs" role="tablist" aria-label="Authentication forms">
                <button type="button" class="auth-switcher__tab" data-action="click->auth-switcher#toggle" data-auth-toggle-target="login" aria-pressed="false">Login</button>
                <button type="button" class="auth-switcher__tab" data-action="click->auth-switcher#toggle" data-auth-toggle-target="register" aria-pressed="false">Register</button>
              </div>
            <% end %>

            <div class="auth-switcher__form auth-switcher__form--login" data-auth-form="login">
              <h3 class="auth-switcher__title">Sign In</h3>

              <%= form_for(login_resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-switcher__form-fields", data: { turbo: false } }) do |f| %>
                <div class="mb-3">
                  <%= f.label :email, class: "visually-hidden" %>
                  <%= f.email_field :email, autofocus: initial_mode == "login", autocomplete: "email", class: "form-control", placeholder: "Email" %>
                </div>

                <div class="mb-3">
                  <%= f.label :password, class: "visually-hidden" %>
                  <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "Password" %>
                </div>

                <% if devise_mapping.rememberable? || devise_mapping.recoverable? %>
                  <div class="auth-switcher__meta">
                    <% if devise_mapping.rememberable? %>
                      <div class="form-check auth-switcher__remember">
                        <%= f.check_box :remember_me, class: "form-check-input" %>
                        <%= f.label :remember_me, class: "form-check-label" %>
                      </div>
                    <% end %>

                    <% if devise_mapping.recoverable? %>
                      <%= link_to "Forgot password?", new_password_path(resource_name), class: "auth-switcher__text-link" %>
                    <% end %>
                  </div>
                <% end %>

                <%= f.submit "Login", class: "btn auth-switcher__submit mt-4 w-100" %>
              <% end %>
            </div>

            <% if registerable %>
              <div class="auth-switcher__form auth-switcher__form--register" data-auth-form="register">
                <h3 class="auth-switcher__title">Register</h3>

                <%= form_for(register_resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-switcher__form-fields", data: { turbo: false } }) do |f| %>
                  <% if register_resource.errors.any? %>
                    <div class="alert alert-danger auth-switcher__errors" role="alert">
                      <strong class="d-block mb-1">Please fix the following:</strong>
                      <ul class="mb-0 ps-3">
                        <% register_resource.errors.full_messages.each do |message| %>
                          <li><%= message %></li>
                        <% end %>
                      </ul>
                    </div>
                  <% end %>

                  <div class="mb-3">
                    <%= f.label :email, class: "visually-hidden" %>
                    <%= f.email_field :email, autofocus: initial_mode == "register", autocomplete: "email", class: "form-control", placeholder: "Email" %>
                  </div>

                  <div class="mb-3">
                    <%= f.label :password, class: "visually-hidden" %>
                    <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "Password" %>
                    <% if @minimum_password_length %>
                      <small class="auth-switcher__hint"><%= @minimum_password_length %> characters minimum</small>
                    <% end %>
                  </div>

                  <div class="mb-3">
                    <%= f.label :password_confirmation, class: "visually-hidden" %>
                    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "Confirm Password" %>
                  </div>

                  <%= f.submit "Register", class: "btn auth-switcher__submit mt-3 w-100" %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
